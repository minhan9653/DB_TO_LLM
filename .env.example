# 공통
LOG_LEVEL=INFO

# Root_Stream 모드/LLM 오버라이드
STREAM_MODE=rag_prompt_llm
LLM_PROVIDER=ollama
OLLAMA_MODEL=qwen2.5:14b
OLLAMA_BASE_URL=http://192.168.0.74:11434/
OPENAI_MODEL=gpt-4.1-mini
OPENAI_API_KEY=

# Root_Stream DB 오버라이드
DB_HOST=127.0.0.1
DB_PORT=1433
DB_NAME=
DB_USER=
DB_PASSWORD=
DB_DRIVER=ODBC Driver 17 for SQL Server
DB_TIMEOUT=30
DB_ENCRYPT=false
DB_TRUST_SERVER_CERTIFICATE=true

# Root_Ingest 오버라이드
EMBEDDING_MODEL_NAME=sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2
CHROMA_COLLECTION_NAME=doc_chunks
CHROMA_PERSIST_DIR=
