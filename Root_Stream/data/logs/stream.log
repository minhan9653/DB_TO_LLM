[2026-04-07 15:56:26] [INFO] [main.py:main:60] ```sql
SELECT 
    eqp.EQPID,
    COUNT(CASE WHEN log.ACTION = 'ERROR' THEN 1 END) AS error_count,
    COUNT(CASE WHEN log.ACTION = 'WARNING' THEN 1 END) AS warning_count,
    (COUNT(CASE WHEN log.ACTION = 'ERROR' THEN 1 END) * 100.0 / (COUNT(CASE WHEN log.ACTION = 'ERROR' THEN 1 ELSE NULL END) + COUNT(CASE WHEN log.ACTION = 'WARNING' THEN 1 ELSE NULL END))) AS error_percentage,
    (COUNT(CASE WHEN log.ACTION = 'WARNING' THEN 1 END) * 100.0 / (COUNT(CASE WHEN log.ACTION = 'ERROR' THEN 1 ELSE NULL END) + COUNT(CASE WHEN log.ACTION = 'WARNING' THEN 1 ELSE NULL END))) AS warning_percentage
FROM 
    ERROR_LOG_DATA eqp
JOIN 
    WARNING_LOG_DATA log
ON 
    eqp.EQPID = log.EQPID
WHERE 
    log.EVENTTIME >= DATEADD(DAY, -30, GETDATE())
GROUP BY 
    eqp.EQPID;
```
